{
  "name": "zealyou-voc-info",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://zealyou-voc-info.pages.dev",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "node --test",
    "preview": "vite preview --host 0.0.0.0",
    "pages:dev": "npm run build && npx wrangler pages dev dist",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name zealyou-voc-info",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.1.2",
    "vite": "^7.1.7"
  },
  "description": "",
  "main": "vite.config.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "wrangler": "^4.92.0"
  }
}
